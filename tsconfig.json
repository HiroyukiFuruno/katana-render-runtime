{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": false,
    "noEmit": true,
    "types": ["node", "bun"]
  },
  "include": [
    "scripts/**/*.ts",
    "crates/katana-diagram-renderer/src/markdown/diagram_runtime/source/**/*.ts"
  ],
  "exclude": [
    "crates/katana-diagram-renderer/src/markdown/diagram_runtime/generated/**",
    "crates/katana-diagram-renderer/vendor/**",
    "target/**",
    "tmp/**"
  ]
}
