{
  "name": "katana-render-runtime",
  "private": true,
  "type": "module",
  "imports": {
    "#shared/*": "./crates/katana-render-runtime/src/markdown/diagram_runtime/source/shared/*.ts",
    "#mermaid/*": "./crates/katana-render-runtime/src/markdown/diagram_runtime/source/mermaid/*.ts",
    "#drawio/*": "./crates/katana-render-runtime/src/markdown/diagram_runtime/source/drawio/*.ts",
    "#zenuml/*": "./crates/katana-render-runtime/src/markdown/diagram_runtime/source/zenuml/*.ts"
  },
  "scripts": {
    "biome": "biome check --error-on-warnings",
    "runtime-bundle:build": "bun run scripts/runtime-bundles/bundle-runtime.ts --write",
    "runtime-bundle:check": "bun run scripts/runtime-bundles/bundle-runtime.ts --check",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@mathjax/src": "4.1.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "acorn": "^8.16.0",
    "playwright": "1.60.0",
    "rollup": "^4.60.4",
    "terser": "^5.48.0",
    "tslib": "^2.8.1",
    "typescript": "6.0.3"
  }
}
