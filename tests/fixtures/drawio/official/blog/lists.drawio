ize=8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="kK7Dx8O5RSM1oxUFZSD2-16" target="kK7Dx8O5RSM1oxUFZSD2-14"><mxGeometry relative="1" as="geometry"><Array as="points"/></mxGeometry></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-20" value="No" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=13;" vertex="1" connectable="0" parent="kK7Dx8O5RSM1oxUFZSD2-19"><mxGeometry x="-0.7381" relative="1" as="geometry"><mxPoint x="1" as="offset"/></mxGeometry></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-16" value="All items?" style="rhombus;whiteSpace=wrap;html=1;fontSize=16;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="-300" y="230" width="80" height="80" as="geometry"/></mxCell></root></mxGraphModel>
