;html=1;fontSize=16;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="kK7Dx8O5RSM1oxUFZSD2-1"><mxGeometry y="226" width="280" height="200" as="geometry"><mxRectangle y="226" width="280" height="30" as="alternateBounds"/></mxGeometry></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-6" value="1. Check inventory." style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontSize=16;" vertex="1" parent="kK7Dx8O5RSM1oxUFZSD2-5"><mxGeometry y="30" width="280" height="30" as="geometry"/></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-7" value="2. Gather items and update inventory." style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontSize=16;" vertex="1" parent="kK7Dx8O5RSM1oxUFZSD2-5"><mxGeometry y="60" width="280" height="30" as="geometry"/></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-8" value="3. Package items and double check against order.&amp;nbsp;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontSize=16;" vertex="1" parent="kK7Dx8O5RSM1oxUFZSD2-5"><mxGeometry y="90" width="280" height="50" as="geometry"/></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-9" value="4. Purchase postage." style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontSize=16;" vertex="1" parent="kK7Dx8O5RSM1oxUFZSD2-5"><mxGeometry y="140" width="280" height="30" as="geometry"/></mxCell><mxCell id="kK7Dx8O5RSM1oxUFZSD2-10" value="5. Send package and notify customer." style="text;strokeColor=none;fillCol